# Postgres connection string (Vercel Postgres, Neon, Supabase, or local Postgres all work)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-secret"

# Your site's URL. http://localhost:3000 for local dev.
NEXTAUTH_URL="http://localhost:3000"

# Anyone creating an author account must know this code.
# Change it, and only share it with people you want to be able to publish.
SIGNUP_CODE="change-this-invite-code"
